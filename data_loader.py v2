from __future__ import annotations

import logging
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path
from typing import Dict, List

import numpy as np
import pandas as pd
import requests
import streamlit as st
import yfinance as yf
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry

import config

logger = logging.getLogger(__name__)

# =========================================================
# HTTP SESSION
# =========================================================

def create_session():

    session = requests.Session()

    retry = Retry(
        total=5,
        connect=5,
        read=5,
        backoff_factor=1,
        status_forcelist=[429,500,502,503,504],
        allowed_methods=["GET"]
    )

    adapter = HTTPAdapter(max_retries=retry)

    session.mount("https://",adapter)
    session.mount("http://",adapter)

    session.headers.update({
        "User-Agent":"Mozilla/5.0"
    })

    return session


SESSION=create_session()

# =========================================================
# CACHE
# =========================================================

CACHE_PATH=config.CACHE_DIR/"market"

CACHE_PATH.mkdir(exist_ok=True)

# =========================================================
# SYMBOL
# =========================================================

def normalize_symbol(symbol:str)->str:

    symbol=symbol.upper().strip()

    if "." not in symbol:

        symbol+=".IS"

    return symbol

# =========================================================
# VALIDATE
# =========================================================

def validate(df:pd.DataFrame)->pd.DataFrame:

    gerekli=["Open","High","Low","Close","Volume"]

    if df.empty:

        raise ValueError("Boş veri")

    if isinstance(df.columns,pd.MultiIndex):

        df.columns=df.columns.get_level_values(0)

    df=df.loc[:,~df.columns.duplicated()]

    eksik=[i for i in gerekli if i not in df.columns]

    if eksik:

        raise ValueError(f"Eksik kolon : {eksik}")

    df=df[gerekli]

    df=df.replace([np.inf,-np.inf],np.nan)

    df=df.dropna()

    return df

# =========================================================
# SINGLE DOWNLOAD
# =========================================================

@st.cache_data(ttl=config.CACHE_TTL)

def load_data(
        symbol:str,
        period=None,
        interval=None
):

    symbol=normalize_symbol(symbol)

    if period is None:

        period=config.DEFAULT_PERIOD

    if interval is None:

        interval=config.DEFAULT_INTERVAL

    logger.info(f"Downloading {symbol}")

    df=yf.download(
        tickers=symbol,
        period=period,
        interval=interval,
        auto_adjust=True,
        progress=False,
        threads=False,
        session=SESSION
    )

    return validate(df)

# =========================================================
# MULTI DOWNLOAD
# =========================================================

def load_many(
        symbols:List[str],
        period=None,
        interval=None,
        workers:int=5
)->Dict[str,pd.DataFrame]:

    result={}

    with ThreadPoolExecutor(max_workers=workers) as executor:

        futures={

            executor.submit(
                load_data,
                s,
                period,
                interval
            ):s

            for s in symbols

        }

        for future in as_completed(futures):

            symbol=futures[future]

            try:

                result[symbol]=future.result()

            except Exception as e:

                logger.warning(f"{symbol} : {e}")

    return result

# =========================================================
# SAVE CACHE
# =========================================================

def save_cache(symbol:str,df:pd.DataFrame):

    file=CACHE_PATH/f"{normalize_symbol(symbol)}.parquet"

    df.to_parquet(file)

# =========================================================
# LOAD CACHE
# =========================================================

def load_cache(symbol:str):

    file=CACHE_PATH/f"{normalize_symbol(symbol)}.parquet"

    if file.exists():

        return pd.read_parquet(file)

    return None

# =========================================================
# PRICE
# =========================================================

def last_price(df):

    return float(df.Close.iloc[-1])

# =========================================================
# CHANGE %
# =========================================================

def daily_change(df):

    return (
        df.Close.iloc[-1]-df.Close.iloc[-2]
    )/df.Close.iloc[-2]*100

# =========================================================
# VOLUME
# =========================================================

def last_volume(df):

    return int(df.Volume.iloc[-1])

# =========================================================
# DATE
# =========================================================

def last_date(df):

    return df.index[-1]